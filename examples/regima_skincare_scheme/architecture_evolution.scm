;; Purging Period Survival Guide
(define-purging-survival-guide
  (what-is-purging
    "Temporary increase in visible issues as deep problems surface during transformation")
  
  (expect-during-purging
    (more-bugs "Hidden issues come to light")
    (slower-velocity "Team learning new patterns")
    (increased-friction "Change resistance")
    (test-failures "Edge cases discovered")
    (user-complaints "Temporary instability"))
  
  (how-to-survive
    (communicate-expectations "Warn stakeholders in advance")
    (protect-users "Feature flags and gradual rollout")
    (support-team "Extra resources during transition")
    (monitor-closely "Daily standup on issues")
    (stay-committed "Don't abandon mid-transformation")
    (be-patient "Light at end of tunnel"))
  
  (when-to-worry
    (purging-exceeds-timeline "Longer than 2x expected")
    (severity-increases "Critical issues emerge")
    (team-morale-collapses "Mass exodus begins")
    (user-exodus "Customer churn spikes")
    (business-impact "Revenue loss significant"))
  
  (recovery-options
    (reduce-intensity "Step down to lower retinol strength")
    (pause-transformation "Stabilize then resume")
    (partial-rollback "Revert problematic areas")
    (increase-support "More resources and oversight")
    (extend-timeline "Slow down the pace")))

