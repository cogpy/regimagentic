    (optimization-schedule
      (real-time "Continuous query optimization")
      (hourly "Cache warming and cleanup")
      (daily "Performance profiling and analysis")
      (weekly "Comprehensive optimization pass")
      (monthly "Deep architectural review")
      (quarterly "Capacity planning and scaling"))
    
    ;; Performance Targets (Youth Maintenance)
    (performance-targets
      (latency-p50 "< 100ms for typical requests")
      (latency-p99 "< 500ms for 99% of requests")
      (throughput "Handle 1000+ req/sec per instance")
      (efficiency "< 50% CPU at steady state")
      (memory-stability "No growth over time")
      (error-rate "< 0.1% failures"))
    
    ;; Degradation Thresholds (Aging Indicators)
    (degradation-alerts
      (performance-drop "> 20% slower than baseline")
      (memory-growth "> 10% increase per week")
      (cpu-saturation "> 80% sustained utilization")
      (cache-hit-decline "> 15% drop in hit rate")
      (error-rate-increase "> 2x baseline errors")))
  
  ;; Performance Characteristics
  (performance
    (optimization-overhead "< 1% of total execution time")
    (improvement-potential "2-10x speedup typical")
    (longevity "Maintain peak performance for years")
    (efficiency-gain "50-80% resource reduction possible")
    (scalability "Linear scaling up to 1000+ instances"))
  
